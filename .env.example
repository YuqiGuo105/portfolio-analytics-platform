# ============================================================================
# portfolio-analytics-platform — local dev environment variables
# ============================================================================
# This file is the CONTRACT, not the source of truth. Copy it to `.env` and
# fill in real values from the Aiven console / your password manager. Never
# commit a populated .env.
#
# Production values live in Cloud Run secret bindings, not here.
# ============================================================================

# ── Aiven Kafka (SASL_SSL / SCRAM-SHA-256) ──────────────────────────────────
# Take these from Aiven console → Service overview → Connection information.
# `KAFKA_CA_CERT` is the PEM-encoded Project CA (multiline OK in .env).
KAFKA_BROKERS=
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_TRUSTSTORE_TYPE=PEM
KAFKA_CA_CERT=

# Aiven Kafka FREE tier: exactly 2 topics allowed. Each at 2 partitions.
# These names must exist on the cluster before the services start
# (auto-creation is disabled on Aiven by default).
ANALYTICS_TOPIC_RAW=analytics.raw.events
ANALYTICS_TOPIC_DLQ=analytics.events.dlq

# ── Aiven Valkey (Redis-compatible, TLS) ────────────────────────────────────
# Used for at-least-once → effectively-once event_id dedup (SETNX) and for
# the dashboard query cache. URL form: rediss://default:PASSWORD@HOST:PORT
VALKEY_URL=

# ── Postgres (shared Supabase instance, separate `analytics` schema) ────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ── Privacy salts ───────────────────────────────────────────────────────────
# 32-byte hex secret. Used by enrichment to HMAC the raw IP before discarding
# it. Rotating this value invalidates historical ip_hash joins by design.
ANALYTICS_HMAC_SALT=

# ── Internal RPC tokens (matches portfolio-notification-service convention) ─
# - INTERNAL_API_TOKEN: incoming token validator on the alerts-service admin
#   CRUD endpoints (same X-Internal-Token pattern as notification-service).
# - NOTIFICATION_INTERNAL_TOKEN: outgoing token alerts-service sends when
#   POSTing to notification-service /api/content-events.
INTERNAL_API_TOKEN=
NOTIFICATION_INTERNAL_TOKEN=
NOTIFICATION_SERVICE_BASE_URL=http://localhost:8082

# ── Per-service ports (docker-compose maps these) ───────────────────────────
AGGREGATOR_PORT=8093
ALERTS_PORT=8094

# ── Aggregator-only knobs ──────────────────────────────────────────
ANALYTICS_SITE_ID=yuqi.site
ANALYTICS_DEDUP_TTL_SECONDS=86400

# Flip true on a one-shot backfill pod to replay visitor_logs +
# visitor_clicks from Supabase through the enrichment + rollup pipeline.
# Always flip back to false on the steady-state consumer pod.
ANALYTICS_BACKFILL_ENABLED=false
ANALYTICS_BACKFILL_BATCH=500
